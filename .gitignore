# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.*.example

# vercel
.vercel

#codex
.codex

# mcp pointer state
.mcp-pointer/

#tmp files
*.tmp

# personal launch notes
docs/LAUNCH-CHECKLIST.md

# transient UI test artifacts
output/playwright/

# typescript
*.tsbuildinfo
next-env.d.ts

# mcp server build artifacts
/mcp-server/dist/
/mcp-server/node_modules/

# local planner data (user data, not for committing)
/data/

# build/test artifacts
test-results/
*.autosave.mp4

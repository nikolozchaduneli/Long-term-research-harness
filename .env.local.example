# AI Provider: "vertex" (Claude) or "azure" (GPT)
AI_PROVIDER=vertex

# Vertex AI (Claude) - requires: gcloud auth application-default login
VERTEX_PROJECT_ID=
VERTEX_REGION=us-east5
VERTEX_MODEL=claude-opus-4-6@20250514
# Effort level: low | medium | high | max (default: high)
VERTEX_EFFORT=high

# Azure OpenAI (GPT) - used when AI_PROVIDER=azure
AZURE_OPENAI_RESPONSES_URL=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure Voice (independent of AI_PROVIDER)
AZURE_VOICE_ENDPOINT=
AZURE_VOICE_API_KEY=
AZURE_VOICE_DEPLOYMENT=
AZURE_VOICE_API_VERSION=2025-03-01-preview
